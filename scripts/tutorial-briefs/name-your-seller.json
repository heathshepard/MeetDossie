  "workflow_group": "general-onboarding",
  "workflow_order": 4,
  "viewport": { "width": 390, "height": 844 },
  "version": 5,
  "pre_auth": true,
  "record_start_after_text": "Pipeline Dashboard",
  "demo_account": "demo@meetdossie.com",
  "steps": [
    { "action": "goto", "url": "https://meetdossie.com/app", "pause_ms": 2200 },
    { "action": "wait_for_selector", "selector": "[aria-label=\"Pipeline\"]", "timeout_ms": 10000, "pause_ms": 400 },
    { "action": "click_aria", "aria": "Pipeline", "pause_ms": 1500 },
    { "action": "wait_for_text", "text": "Pipeline Dashboard", "timeout_ms": 8000, "pause_ms": 2500 },
    { "action": "click_text", "text": "Sandra Martinez", "exact": false, "pause_ms": 2500 },
    { "action": "wait_for_text", "text": "Deal details", "timeout_ms": 8000, "pause_ms": 800 },
    { "action": "scroll", "y": 600, "pause_ms": 900 },
    { "action": "scroll", "y": 400, "pause_ms": 900 },
    { "action": "click_button_text", "text": "Sandra Martinez", "pause_ms": 900 },
    { "action": "press", "key": "Control+a", "pause_ms": 200 },
    { "action": "type", "value": "Sandra K. Martinez", "delay_ms": 60, "pause_ms": 900 },
