{
  "slug": "name-your-seller",
  "title": "Name Your Seller on a Dossier",
  "description": "Drop your seller's name into the file so every disclosure, amendment, and milestone goes out under their name.",
  "voiceover_script": "Hi, I'm Dossie. If you represent the seller, drop their name into the dossier so every disclosure and amendment goes out under their name. Open the file, tap the seller's name, and type it in. From now on, every contract I draft is theirs automatically.",
  "tags": ["onboarding", "dossier", "seller", "client-info"],
