{
    "buildCommand": "",
    "outputDirectory": ".",
    "rewrites":  [
                     {
                         "destination":  "/index.html",
                         "source":  "/"
                     },
                     {
                         "source":  "/founding",
                         "destination":  "/founding.html"
                     },
                     {
                         "source":  "/welcome",
                         "destination":  "/welcome.html"
                     },
                     {
                         "source":  "/set-password",
                         "destination":  "/set-password.html"
                     },
                     {
                         "source":  "/forgot-password",
                         "destination":  "/forgot-password.html"
                     },
                     {
                         "source":  "/signin",
                         "destination":  "/app.html"
                     },
                     {
                         "source":  "/workspace",
                         "destination":  "/workspace.html"
                     },
                     {
                         "source":  "/app",
                         "destination":  "/app.html"
                     },
                     {
                         "source":  "/calculator",
                         "destination":  "/calculator.html"
                     },
                     {
                         "source":  "/privacy",
                         "destination":  "/privacy.html"
                     },
                     {
                         "source":  "/terms",
                         "destination":  "/terms.html"
                     },
                     {
                         "source":  "/ventures",
                         "destination":  "/ventures.html"
                     },
                     {
                         "source":  "/studio",
                         "destination":  "/ventures.html"
                     }
                 ],
    "headers":  [
                    {
                        "source":  "/(.*).html",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-cache, no-store, must-revalidate"
                                        }
                                    ]
                    },
                    {
                        "source":  "/assets/(.*)",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=3600, must-revalidate"
                                        }
                                    ]
                    },
                    {
                        "source":  "/manifest.webmanifest",
                        "headers":  [
                                        {
                                            "key":  "Content-Type",
                                            "value":  "application/manifest+json"
                                        },
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=3600, must-revalidate"
                                        }
                                    ]
                    },
                    {
                        "source":  "/icons/(.*)",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=86400, must-revalidate"
                                        }
                                    ]
                    }
                ],
    "functions":  {
                      "api/telegram-webhook.js":  {
                                                      "maxDuration":  30
                                                  },
                      "api/cron-generate-posts.js":  {
                                                         "maxDuration":  90
                                                     },
                      "api/cron-publish-approved.js":  {
                                                           "maxDuration":  120
                                                       },
                      "api/cron-weekly-newsletter.js":  {
                                                            "maxDuration":  60,
                                                            "includeFiles":  "WEEKLY-IMPROVEMENTS.md"
                                                        },
                      "api/generate-broll.js":  {
                                                    "maxDuration":  120
                                                }
                  },
    "crons":  [
                  {
                      "path":  "/api/alert-health",
                      "schedule":  "*/5 * * * *"
                  },
                  {
                      "path":  "/api/cron-followup",
                      "schedule":  "0 12 * * *"
                  },
                  {
                      "path":  "/api/cron-generate-posts",
                      "schedule":  "0 11 * * *"
                  },
                  {
                      "path":  "/api/cron-send-for-approval",
                      "schedule":  "30 11 * * *"
                  },
                  {
                      "path":  "/api/cron-publish-approved",
                      "schedule":  "*/30 * * * *"
                  },
                  {
                      "path":  "/api/cron-content-brief",
                      "schedule":  "0 14 * * 1-5"
                  },
                  {
                      "path":  "/api/cron-calculator-deadline-reminders",
                      "schedule":  "0 13 * * *"
                  },
                  {
                      "path":  "/api/cron-email-digest",
                      "schedule":  "0 13 * * *"
                  },
                  {
                      "path":  "/api/cron-deadline-reminders",
                      "schedule":  "5 13 * * *"
                  },
                  {
                      "path":  "/api/cron-pipeline-health",
                      "schedule":  "0 13 * * *"
                  },
                  {
                      "path":  "/api/cron-morning-brief",
                      "schedule":  "0 12 * * *"
                  },
                  {
                      "path":  "/api/cron-weekly-newsletter",
                      "schedule":  "0 15 * * 5"
                  }
              ]
}
