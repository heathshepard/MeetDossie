{
    "buildCommand": "",
    "outputDirectory": ".",
    "rewrites":  [
                     {
                         "destination":  "/index.html",
                         "source":  "/"
                     },
                     {
                         "source":  "/founding",
                         "destination":  "/founding.html"
                     },
                     {
                         "source":  "/welcome",
                         "destination":  "/welcome.html"
                     },
                     {
                         "source":  "/set-password",
                         "destination":  "/set-password.html"
                     },
                     {
                         "source":  "/forgot-password",
                         "destination":  "/forgot-password.html"
                     },
                     {
                         "source":  "/signin",
                         "destination":  "/signin.html"
                     },
                     {
                         "source":  "/workspace",
                         "destination":  "/workspace.html"
                     },
                     {
                         "source":  "/app",
                         "destination":  "/app.html"
                     },
                     {
                         "source":  "/calculator",
                         "destination":  "/calculator.html"
                     }
                 ],
    "headers":  [
                    {
                        "source":  "/(.*).html",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "no-cache, no-store, must-revalidate"
                                        }
                                    ]
                    },
                    {
                        "source":  "/assets/(.*)",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=3600, must-revalidate"
                                        }
                                    ]
                    }
                ],
    "functions":  {
                      "api/cron-generate-posts.js":  {
                                                         "maxDuration":  90
                                                     },
                      "api/cron-publish-approved.js":  {
                                                           "maxDuration":  120
                                                       }
                  },
    "crons":  [
                  {
                      "path":  "/api/alert-health",
                      "schedule":  "*/5 * * * *"
                  },
                  {
                      "path":  "/api/cron-followup",
                      "schedule":  "0 12 * * *"
                  },
                  {
                      "path":  "/api/cron-generate-posts",
                      "schedule":  "0 11 * * *"
                  },
                  {
                      "path":  "/api/cron-send-for-approval",
                      "schedule":  "30 11 * * *"
                  },
                  {
                      "path":  "/api/cron-publish-approved",
                      "schedule":  "*/30 * * * *"
                  },
                  {
                      "path":  "/api/cron-content-brief",
                      "schedule":  "0 14 * * 1-5"
                  },
                  {
                      "path":  "/api/cron-deadline-reminders",
                      "schedule":  "0 13 * * *"
                  }
              ]
}
