{
  "rewrites": [
    { "source": "/founding", "destination": "/founding.html" },
    { "source": "/welcome", "destination": "/welcome.html" },
    { "source": "/set-password", "destination": "/set-password.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/signin", "destination": "/signin.html" },
    { "source": "/workspace", "destination": "/workspace.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/calculator", "destination": "/calculator.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/render-card.py": {
      "runtime": "@vercel/python@4.3.1",
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "Media/_fonts/**;Media/dossie-logo-d.png"
    },
    "api/cron-generate-posts.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron-followup",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron-generate-posts",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron-send-for-approval",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron-publish-approved",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron-content-brief",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron-deadline-reminders",
      "schedule": "0 13 * * *"
    }
  ]
}
