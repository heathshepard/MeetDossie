{
  "rewrites": [
    { "source": "/founding", "destination": "/founding.html" },
    { "source": "/welcome", "destination": "/welcome.html" },
    { "source": "/set-password", "destination": "/set-password.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/signin", "destination": "/signin.html" },
    { "source": "/workspace", "destination": "/workspace.html" },
    { "source": "/app", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-followup",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron-generate-posts",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron-send-for-approval",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron-publish-approved",
      "schedule": "*/30 * * * *"
    }
  ]
}
