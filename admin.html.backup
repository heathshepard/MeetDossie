<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard — Dossie</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23E8927C'/><text y='.9em' font-size='90' x='10'>D</text></svg>">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --bg: #FDFCFA; --bg-warm: #F9F6F1; --bg-card: #FFFFFF; --bg-dark: #1A1A2E;
  --border: #E8E2D9; --border-light: #F0EBE3;
  --text-primary: #2D2A26; --text-secondary: #7A7468; --text-light: #A39E94;
  --blush: #D4A0A0; --blush-light: #F2E4E4; --blush-deep: #C08080;
  --sage: #8FAF8F; --sage-light: #E4EDE2; --sage-deep: #6B8E68;
  --gold: #C9A84C; --gold-light: #F5EDD8; --gold-deep: #A48531;
  --coral: #E8836B; --coral-light: #FCE4DC; --coral-deep: #C9624A;
  --navy: #1A1A2E;
}

body {
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
  padding: 0;
  margin: 0;
}

.header {
  background: var(--navy);
  color: white;
  padding: 24px 32px;
  border-bottom: 2px solid var(--gold);
}

.header h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 700;
  margin: 0;
  color: white;
}

.header .sub {
  font-size: 14px;
  color: var(--blush-light);
  margin-top: 4px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.header .refresh-badge {
  padding: 4px 10px;
  background: rgba(255,255,255,0.1);
  border-radius: 12px;
  font-size: 11px;
  color: var(--gold-light);
  font-weight: 600;
}

.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 32px;
}

.section {
  margin-bottom: 40px;
}

.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  font-weight: 600;
  color: var(--navy);
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 2px solid var(--blush);
}

.cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px;
}

.card {
  background: var(--bg-card);
  border: 1px solid var(--border-light);
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 4px 12px rgba(45,42,38,0.06);
  transition: transform 0.15s, box-shadow 0.15s;
}

.card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(45,42,38,0.1);
}

.card-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.card-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 42px;
  font-weight: 700;
  color: var(--navy);
  line-height: 1;
}

.card-sublabel {
  font-size: 13px;
  color: var(--text-light);
  margin-top: 6px;
}

.card.highlight {
  background: linear-gradient(135deg, var(--blush-light) 0%, var(--gold-light) 100%);
  border-color: var(--gold);
}

.card.highlight .card-value {
  background: linear-gradient(135deg, var(--blush-deep) 0%, var(--gold-deep) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.table-card {
  background: var(--bg-card);
  border: 1px solid var(--border-light);
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 4px 12px rgba(45,42,38,0.06);
  overflow: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
}

.data-table th {
  text-align: left;
  padding: 12px 16px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text-secondary);
  border-bottom: 2px solid var(--border-light);
}

.data-table td {
  padding: 14px 16px;
  font-size: 15px;
  color: var(--text-primary);
  border-bottom: 1px solid var(--border-light);
}

.data-table tr:last-child td {
  border-bottom: none;
}

.badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 700;
}

.badge.sage {
  background: var(--sage-light);
  color: var(--sage-deep);
}

.badge.coral {
  background: var(--coral-light);
  color: var(--coral-deep);
}

.badge.gold {
  background: var(--gold-light);
  color: var(--gold-deep);
}

.loading {
  text-align: center;
  padding: 80px 20px;
  color: var(--text-secondary);
}

.loading-spinner {
  font-size: 40px;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error {
  background: var(--coral-light);
  border: 1px solid var(--coral);
  border-radius: 12px;
  padding: 20px;
  color: var(--coral-deep);
  margin: 20px 0;
}

.empty-state {
  text-align: center;
  padding: 40px;
  color: var(--text-light);
  font-style: italic;
}
</style>
</head>
<body>

<div class="header">
  <h1>Admin Dashboard</h1>
  <div class="sub">
    <span>Dossie Analytics</span>
    <span class="refresh-badge" id="last-refresh">Auto-refresh: 5min</span>
  </div>
</div>

<div class="container">
  <div id="loading" class="loading">
    <div class="loading-spinner">⏳</div>
    <p>Loading analytics...</p>
  </div>

  <div id="error" style="display:none;"></div>

  <div id="dashboard" style="display:none;">

    <!-- REVENUE & GROWTH -->
    <div class="section">
      <h2 class="section-title">Revenue & Growth</h2>
      <div class="cards">
        <div class="card highlight">
          <div class="card-label">Total MRR</div>
          <div class="card-value" id="mrr-value">$0</div>
          <div class="card-sublabel">Monthly Recurring Revenue</div>
        </div>
        <div class="card">
          <div class="card-label">Founding Members</div>
          <div class="card-value" id="founding-count">0</div>
          <div class="card-sublabel"><span id="founding-remaining">50</span> spots remaining</div>
        </div>
        <div class="card">
          <div class="card-label">Solo Members</div>
          <div class="card-value" id="solo-count">0</div>
          <div class="card-sublabel">$79/mo each</div>
        </div>
        <div class="card">
          <div class="card-label">Team Members</div>
          <div class="card-value" id="team-count">0</div>
          <div class="card-sublabel">$199/mo each</div>
        </div>
        <div class="card">
          <div class="card-label">Total Active</div>
          <div class="card-value" id="total-active">0</div>
          <div class="card-sublabel">Paying subscribers</div>
        </div>
        <div class="card">
          <div class="card-label">Cancellations</div>
          <div class="card-value" id="cancellations">0</div>
          <div class="card-sublabel">This month</div>
        </div>
      </div>
    </div>

    <!-- USER ACTIVITY -->
    <div class="section">
      <h2 class="section-title">User Activity</h2>
      <div class="cards">
        <div class="card">
          <div class="card-label">Total Users</div>
          <div class="card-value" id="total-users">0</div>
          <div class="card-sublabel">Registered accounts</div>
        </div>
        <div class="card">
          <div class="card-label">Active 7 Days</div>
          <div class="card-value" id="active-7d">0</div>
          <div class="card-sublabel">Logged in past week</div>
        </div>
        <div class="card">
          <div class="card-label">Active 30 Days</div>
          <div class="card-value" id="active-30d">0</div>
          <div class="card-sublabel">Logged in past month</div>
        </div>
        <div class="card">
          <div class="card-label">Never Logged In</div>
          <div class="card-value" id="never-logged">0</div>
          <div class="card-sublabel">Signed up, no login</div>
        </div>
      </div>
    </div>

    <!-- PRODUCT USAGE -->
    <div class="section">
      <h2 class="section-title">Product Usage</h2>
      <div class="cards">
        <div class="card">
          <div class="card-label">Total Dossiers</div>
          <div class="card-value" id="total-dossiers">0</div>
          <div class="card-sublabel">All time</div>
        </div>
        <div class="card">
          <div class="card-label">Active Dossiers</div>
          <div class="card-value" id="active-dossiers">0</div>
          <div class="card-sublabel">Currently open</div>
        </div>
        <div class="card">
          <div class="card-label">Closed Dossiers</div>
          <div class="card-value" id="closed-dossiers">0</div>
          <div class="card-sublabel">Completed deals</div>
        </div>
        <div class="card">
          <div class="card-label">Contracts Scanned</div>
          <div class="card-value" id="contracts-week">0</div>
          <div class="card-sublabel">This week</div>
        </div>
        <div class="card">
          <div class="card-label">Morning Brief Plays</div>
          <div class="card-value" id="brief-plays">0</div>
          <div class="card-sublabel">This week</div>
        </div>
        <div class="card">
          <div class="card-label">Talk to Dossie</div>
          <div class="card-value" id="talk-sessions">0</div>
          <div class="card-sublabel">Sessions this week</div>
        </div>
        <div class="card">
          <div class="card-label">Emails Drafted</div>
          <div class="card-value" id="emails-week">0</div>
          <div class="card-sublabel">This week</div>
        </div>
        <div class="card">
          <div class="card-label">Documents Uploaded</div>
          <div class="card-value" id="docs-week">0</div>
          <div class="card-sublabel">This week</div>
        </div>
      </div>
    </div>

    <!-- PIPELINE HEALTH -->
    <div class="section">
      <h2 class="section-title">Pipeline Health</h2>
      <div class="cards">
        <div class="card">
          <div class="card-label">Avg Deals / User</div>
          <div class="card-value" id="avg-deals">0</div>
          <div class="card-sublabel">Per active user</div>
        </div>
        <div class="card">
          <div class="card-label">Milestone Cards</div>
          <div class="card-value" id="milestone-cards">0</div>
          <div class="card-sublabel">Generated total</div>
        </div>
      </div>

      <div class="table-card" style="margin-top: 20px;">
        <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 20px; margin-bottom: 16px; color: var(--navy);">Deals by Stage</h3>
        <table class="data-table" id="stage-table">
          <thead>
            <tr>
              <th>Stage</th>
              <th>Count</th>
            </tr>
          </thead>
          <tbody id="stage-tbody">
            <tr><td colspan="2" class="empty-state">No data</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SOCIAL PIPELINE -->
    <div class="section">
      <h2 class="section-title">Social Pipeline</h2>
      <div class="cards">
        <div class="card">
          <div class="card-label">Generated Today</div>
          <div class="card-value" id="posts-gen-today">0</div>
          <div class="card-sublabel"><span id="posts-gen-week">0</span> this week</div>
        </div>
        <div class="card">
          <div class="card-label">Published Today</div>
          <div class="card-value" id="posts-pub-today">0</div>
          <div class="card-sublabel"><span id="posts-pub-week">0</span> this week</div>
        </div>
        <div class="card">
          <div class="card-label">Failed Today</div>
          <div class="card-value" id="posts-fail-today">0</div>
          <div class="card-sublabel"><span id="posts-fail-week">0</span> this week</div>
        </div>
        <div class="card highlight">
          <div class="card-label">Success Rate</div>
          <div class="card-value" id="success-rate">100%</div>
          <div class="card-sublabel">This week</div>
        </div>
      </div>

      <div class="table-card" style="margin-top: 20px;">
        <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 20px; margin-bottom: 16px; color: var(--navy);">Posts by Platform (This Week)</h3>
        <table class="data-table" id="platform-table">
          <thead>
            <tr>
              <th>Platform</th>
              <th>Posts</th>
            </tr>
          </thead>
          <tbody id="platform-tbody">
            <tr><td colspan="2" class="empty-state">No data</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
let supabase;
let refreshInterval;

async function initSupabase() {
  const configResponse = await fetch('/api/public-config');
  const config = await configResponse.json();
  supabase = window.supabase.createClient(config.supabaseUrl, config.supabaseAnonKey);
}

async function checkAuth() {
  if (!supabase) await initSupabase();
  const { data: { session } } = await supabase.auth.getSession();

  if (!session) {
    window.location.href = '/app.html';
    return null;
  }

  // Check if user email is heath.shepard@kw.com
  if (session.user.email !== 'heath.shepard@kw.com') {
    document.getElementById('loading').style.display = 'none';
    document.getElementById('error').style.display = 'block';
    document.getElementById('error').innerHTML = `
      <div class="error">
        <strong>Access Denied</strong><br>
        This dashboard is only accessible to administrators.
      </div>
    `;
    return null;
  }

  return session;
}

async function loadDashboard() {
  const session = await checkAuth();
  if (!session) return;

  try {
    const response = await fetch('/api/admin-dashboard', {
      headers: {
        'Authorization': `Bearer ${session.access_token}`,
      },
    });

    if (!response.ok) {
      throw new Error(`API error: ${response.status}`);
    }

    const data = await response.json();

    if (!data.success) {
      throw new Error(data.error || 'Unknown error');
    }

    renderDashboard(data.metrics);

    document.getElementById('loading').style.display = 'none';
    document.getElementById('dashboard').style.display = 'block';

    // Update last refresh time
    const now = new Date();
    document.getElementById('last-refresh').textContent =
      `Last: ${now.toLocaleTimeString()} · Auto-refresh: 5min`;

  } catch (error) {
    console.error('Dashboard error:', error);
    document.getElementById('loading').style.display = 'none';
    document.getElementById('error').style.display = 'block';
    document.getElementById('error').innerHTML = `
      <div class="error">
        <strong>Error loading dashboard</strong><br>
        ${error.message}
      </div>
    `;
  }
}

function renderDashboard(metrics) {
  // Revenue
  document.getElementById('mrr-value').textContent = `$${metrics.revenue.mrr.toLocaleString()}`;
  document.getElementById('founding-count').textContent = metrics.revenue.foundingCount;
  document.getElementById('founding-remaining').textContent = metrics.revenue.foundingRemaining;
  document.getElementById('solo-count').textContent = metrics.revenue.soloCount;
  document.getElementById('team-count').textContent = metrics.revenue.teamCount;
  document.getElementById('total-active').textContent = metrics.revenue.totalActive;
  document.getElementById('cancellations').textContent = metrics.revenue.cancellationsThisMonth;

  // Users
  document.getElementById('total-users').textContent = metrics.users.total;
  document.getElementById('active-7d').textContent = metrics.users.active7d;
  document.getElementById('active-30d').textContent = metrics.users.active30d;
  document.getElementById('never-logged').textContent = metrics.users.neverLoggedIn;

  // Usage
  document.getElementById('total-dossiers').textContent = metrics.usage.totalDossiers;
  document.getElementById('active-dossiers').textContent = metrics.usage.activeDossiers;
  document.getElementById('closed-dossiers').textContent = metrics.usage.closedDossiers;
  document.getElementById('contracts-week').textContent = metrics.usage.contractsThisWeek;
  document.getElementById('brief-plays').textContent = metrics.usage.morningBriefPlays;
  document.getElementById('talk-sessions').textContent = metrics.usage.talkSessions;
  document.getElementById('emails-week').textContent = metrics.usage.emailsThisWeek;
  document.getElementById('docs-week').textContent = metrics.usage.docsThisWeek;

  // Pipeline
  document.getElementById('avg-deals').textContent = metrics.pipeline.avgDealsPerUser;
  document.getElementById('milestone-cards').textContent = metrics.pipeline.milestoneCards;

  // Deals by stage
  const stageTbody = document.getElementById('stage-tbody');
  const stages = Object.entries(metrics.pipeline.dealsByStage);
  if (stages.length > 0) {
    stageTbody.innerHTML = stages
      .sort((a, b) => b[1] - a[1])
      .map(([stage, count]) => `
        <tr>
          <td><strong>${stage}</strong></td>
          <td>${count}</td>
        </tr>
      `).join('');
  }

  // Social
  document.getElementById('posts-gen-today').textContent = metrics.social.generatedToday;
  document.getElementById('posts-gen-week').textContent = metrics.social.generatedThisWeek;
  document.getElementById('posts-pub-today').textContent = metrics.social.publishedToday;
  document.getElementById('posts-pub-week').textContent = metrics.social.publishedThisWeek;
  document.getElementById('posts-fail-today').textContent = metrics.social.failedToday;
  document.getElementById('posts-fail-week').textContent = metrics.social.failedThisWeek;
  document.getElementById('success-rate').textContent = metrics.social.successRate;

  // Platform breakdown
  const platformTbody = document.getElementById('platform-tbody');
  const platforms = Object.entries(metrics.social.platformCounts);
  if (platforms.length > 0) {
    platformTbody.innerHTML = platforms
      .sort((a, b) => b[1] - a[1])
      .map(([platform, count]) => `
        <tr>
          <td><strong>${platform}</strong></td>
          <td>${count}</td>
        </tr>
      `).join('');
  }
}

// Load dashboard on page load
loadDashboard();

// Auto-refresh every 5 minutes (300000ms)
refreshInterval = setInterval(loadDashboard, 300000);
</script>

</body>
</html>
